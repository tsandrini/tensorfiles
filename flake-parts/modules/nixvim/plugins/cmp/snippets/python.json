{
  "argparse + logging entrypoint": {
    "prefix": "pymain",
    "description": "Script entrypoint with argparse, logging and a standard main()",
    "body": [
      "import argparse",
      "import logging",
      "import sys",
      "import os",
      "",
      "log = logging.getLogger(\"${1:prog_name}\")",
      "",
      "",
      "def parse_args() -> argparse.Namespace:",
      "    p = argparse.ArgumentParser(",
      "        prog=\"${1:prog_name}\",",
      "        description=\"${2:Lorem ipsum}\",",
      "        formatter_class=argparse.ArgumentDefaultsHelpFormatter,",
      "    )",
      "",
      "    p.add_argument(\"--arg\", default=None, help=\"Argument\")",
      "",
      "    p.add_argument(",
      "        \"--log-level\",",
      "        default=os.getenv(\"LOG_LEVEL\", \"INFO\"),",
      "        choices=[\"CRITICAL\", \"ERROR\", \"WARNING\", \"INFO\", \"DEBUG\", \"NOTSET\"],",
      "        help=\"Logging level\",",
      "    )",
      "",
      "    args = p.parse_args()",
      "    return args",
      "",
      "",
      "def setup_logging(level_name: str) -> None:",
      "    level = getattr(logging, level_name.upper(), logging.INFO)",
      "    logging.basicConfig(",
      "        level=level,",
      "        format=\"%(asctime)s %(levelname)s %(name)s: %(message)s\",",
      "        datefmt=\"%Y-%m-%d %H:%M:%S\",",
      "        stream=sys.stdout,",
      "    )",
      "",
      "",
      "def main() -> None:",
      "    args = parse_args()",
      "    setup_logging(args.log_level)",
      "    $0",
      "",
      "",
      "if __name__ == \"__main__\":",
      "    main()"
    ]
  }
}

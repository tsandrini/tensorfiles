{
  "argparse + logging entrypoint": {
    "prefix": "pymain",
    "description": "Script entrypoint with argparse, logging and a standard main()",
    "body": [
      "import argparse",
      "import logging",
      "import sys",
      "import os",
      "",
      "logger = logging.getLogger(\"${1:prog_name}\")",
      "",
      "",
      "def parse_args() -> argparse.Namespace:",
      "    p = argparse.ArgumentParser(",
      "        prog=\"${1:prog_name}\",",
      "        description=\"${2:Lorem ipsum}\",",
      "        formatter_class=argparse.ArgumentDefaultsHelpFormatter,",
      "    )",
      "",
      "    p.add_argument(\"--arg\", default=None, help=\"Argument\")",
      "",
      "    p.add_argument(",
      "        \"--log-level\",",
      "        default=os.getenv(\"LOG_LEVEL\", \"INFO\"),",
      "        choices=[\"CRITICAL\", \"ERROR\", \"WARNING\", \"INFO\", \"DEBUG\", \"NOTSET\"],",
      "        help=\"Logging level\",",
      "    )",
      "",
      "    args = p.parse_args()",
      "    return args",
      "",
      "",
      "def setup_logging(level_name: str) -> None:",
      "    level = getattr(logging, level_name.upper(), logging.INFO)",
      "    logging.basicConfig(",
      "        level=level,",
      "        format=\"%(asctime)s %(levelname)s %(name)s: %(message)s\",",
      "        datefmt=\"%Y-%m-%d %H:%M:%S\",",
      "        stream=sys.stdout,",
      "    )",
      "",
      "",
      "def main() -> None:",
      "    args = parse_args()",
      "    setup_logging(args.log_level)",
      "    $0",
      "",
      "",
      "if __name__ == \"__main__\":",
      "    main()"
    ]
  },
  "argparse + logging async entrypoint": {
    "prefix": "pyasyncmain",
    "description": "Async script entrypoint with argparse, logging and asyncio.run(main())",
    "body": [
      "import argparse",
      "import asyncio",
      "import logging",
      "import sys",
      "import os",
      "",
      "logger = logging.getLogger(\"${1:prog_name}\")",
      "",
      "",
      "def parse_args() -> argparse.Namespace:",
      "    p = argparse.ArgumentParser(",
      "        prog=\"${1:prog_name}\",",
      "        description=\"${2:Lorem ipsum}\",",
      "        formatter_class=argparse.ArgumentDefaultsHelpFormatter,",
      "    )",
      "",
      "    p.add_argument(\"--arg\", default=None, help=\"Argument\")",
      "",
      "    p.add_argument(",
      "        \"--log-level\",",
      "        default=os.getenv(\"LOG_LEVEL\", \"INFO\"),",
      "        choices=[\"CRITICAL\", \"ERROR\", \"WARNING\", \"INFO\", \"DEBUG\", \"NOTSET\"],",
      "        help=\"Logging level\",",
      "    )",
      "",
      "    args = p.parse_args()",
      "    return args",
      "",
      "",
      "def setup_logging(level_name: str) -> None:",
      "    level = getattr(logging, level_name.upper(), logging.INFO)",
      "    logging.basicConfig(",
      "        level=level,",
      "        format=\"%(asctime)s %(levelname)s %(name)s: %(message)s\",",
      "        datefmt=\"%Y-%m-%d %H:%M:%S\",",
      "        stream=sys.stdout,",
      "    )",
      "",
      "",
      "async def main() -> None:",
      "    args = parse_args()",
      "    setup_logging(args.log_level)",
      "    $0",
      "",
      "",
      "if __name__ == \"__main__\":",
      "    asyncio.run(main())"
    ]
  },
  "pytest test module scaffold": {
    "prefix": "pytest",
    "description": "Test module scaffold with a parametrized test against an imported function",
    "body": [
      "import pytest",
      "",
      "from ${1:module} import ${2:func}",
      "",
      "",
      "@pytest.mark.parametrize(",
      "    (\"${3:inp}\", \"${4:expected}\"),",
      "    [",
      "        ($5, $6),",
      "        $0",
      "    ],",
      ")",
      "def test_${2:func}(${3:inp}, ${4:expected}) -> None:",
      "    assert ${2:func}(${3:inp}) == ${4:expected}"
    ]
  },
  "pytest parametrize block": {
    "prefix": "pyparam",
    "description": "Parametrized test function (no imports)",
    "body": [
      "@pytest.mark.parametrize(",
      "    (\"${2:inp}\", \"${3:expected}\"),",
      "    [",
      "        ($4, $5),",
      "        $0",
      "    ],",
      ")",
      "def test_${1:func}(${2:inp}, ${3:expected}) -> None:",
      "    assert ${1:func}(${2:inp}) == ${3:expected}"
    ]
  },
  "pytest fixture": {
    "prefix": "pyfix",
    "description": "pytest fixture stub",
    "body": ["@pytest.fixture", "def ${1:name}():", "    $0"]
  },
  "pytest async test module scaffold": {
    "prefix": "pyatest",
    "description": "Test module scaffold for an async function, using asyncio.run() (no pytest-asyncio dep)",
    "body": [
      "import asyncio",
      "",
      "import pytest",
      "",
      "from ${1:module} import ${2:func}",
      "",
      "",
      "@pytest.mark.parametrize(",
      "    (\"${3:inp}\", \"${4:expected}\"),",
      "    [",
      "        ($5, $6),",
      "        $0",
      "    ],",
      ")",
      "def test_${2:func}(${3:inp}, ${4:expected}) -> None:",
      "    assert asyncio.run(${2:func}(${3:inp})) == ${4:expected}"
    ]
  },
  "pytest.raises block": {
    "prefix": "pyraises",
    "description": "Assert that a call raises a given exception",
    "body": ["with pytest.raises(${1:ValueError}):", "    $0"]
  }
}
